{
  "name": "dropaigc-recovered",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "node server.mjs",
    "dev": "npm run build:frontend && NODE_ENV=development node --watch server.mjs",
    "dev:frontend": "vite --config frontend/vite.config.js",
    "build:frontend": "vite build --config frontend/vite.config.js",
    "sync:deployed": "node scripts/sync-deployed.mjs",
    "check": "node --check server.mjs && node --check src/server/api.mjs && node --check src/server/llm.mjs && node --check src/server/reports.mjs",
    "test": "node test/store-blob.mjs && node test/smoke.mjs"
  },
  "dependencies": {
    "@vercel/blob": "^2.6.1",
    "busboy": "^1.6.0",
    "docx": "^9.5.1",
    "lucide-react": "^0.468.0",
    "mammoth": "^1.12.0",
    "pdf-parse": "^2.4.5",
    "react": "^19.1.1",
    "react-dom": "^19.1.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "vite": "^6.0.7"
  }
}
