{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build:frontend",
  "outputDirectory": "web-dist",
  "functions": {
    "api/index.mjs": { "maxDuration": 60, "includeFiles": "data/**" }
  },
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/index?path=:path" },
    { "source": "/((?!api/|assets/|favicon.ico|manifest.webmanifest).*)", "destination": "/index.html" }
  ],
  "headers": [
    { "source": "/(.*)", "headers": [
      { "key": "X-Content-Type-Options", "value": "nosniff" },
      { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
      { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
      { "key": "Permissions-Policy", "value": "camera=(self), microphone=(self), geolocation=()" },
      { "key": "Content-Security-Policy", "value": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: https:; media-src 'self' blob: https:; connect-src 'self' https://api.deepseek.com; font-src 'self' data:; frame-ancestors 'self'; base-uri 'self'; form-action 'self'" }
    ] }
  ]
}
